{
  "name": "invisible-errors-detector",
  "displayName": "Invisible Errors Detector",
  "description": "Static analysis tool that finds bugs traditional linters miss (logic, security, code smells, framework patterns).",
  "version": "0.1.0",
  "publisher": "invisible-errors",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "linter",
    "static-analysis",
    "bugs",
    "security",
    "react",
    "vue",
    "typescript"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onLanguage:python",
    "onLanguage:go"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "invisibleErrors.analyzeWorkspace",
        "title": "Invisible Errors: Analyze Workspace"
      },
      {
        "command": "invisibleErrors.analyzeFile",
        "title": "Invisible Errors: Analyze Current File"
      },
      {
        "command": "invisibleErrors.clearCache",
        "title": "Invisible Errors: Clear Cache"
      },
      {
        "command": "invisibleErrors.showDashboard",
        "title": "Invisible Errors: Show Dashboard"
      },
      {
        "command": "invisibleErrors.exportReport",
        "title": "Invisible Errors: Export Report (JSON/HTML/SARIF)"
      },
      {
        "command": "invisibleErrors.cancelAnalysis",
        "title": "Invisible Errors: Cancel Running Analysis"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "invisibleErrors.issues",
          "name": "Invisible Errors",
          "icon": "$(bug)"
        }
      ]
    },
    "configuration": {
      "title": "Invisible Errors Detector",
      "properties": {
        "invisibleErrors.enable": {
          "type": "boolean",
          "default": true
        },
        "invisibleErrors.runOnSave": {
          "type": "boolean",
          "default": true
        },
        "invisibleErrors.runOnType": {
          "type": "boolean",
          "default": true
        },
        "invisibleErrors.debounceMs": {
          "type": "number",
          "default": 400
        },
        "invisibleErrors.maxFileSize": {
          "type": "number",
          "default": 1000000
        },
        "invisibleErrors.rules": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string",
            "enum": [
              "off",
              "info",
              "warning",
              "error"
            ]
          }
        },
        "invisibleErrors.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/out/**",
            "**/build/**",
            "**/.git/**"
          ]
        },
        "invisibleErrors.performance": {
          "type": "object",
          "default": {
            "parallelAnalysis": true,
            "maxWorkers": 4,
            "cacheSize": 200
          },
          "properties": {
            "parallelAnalysis": {
              "type": "boolean",
              "default": true
            },
            "maxWorkers": {
              "type": "number",
              "default": 4
            },
            "cacheSize": {
              "type": "number",
              "default": 200
            }
          }
        },
        "invisibleErrors.anyTypeThreshold": {
          "type": "number",
          "default": 5
        },
        "invisibleErrors.allowConsoleInCli": {
          "type": "boolean",
          "default": true
        },
        "invisibleErrors.useLsp": {
          "type": "boolean",
          "default": false,
          "description": "Use the @ied/lsp language server instead of in-process analysis (parity testing; same engine, different transport)."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "invisibleErrors.analyzeWorkspace",
          "when": "view == invisibleErrors.issues",
          "group": "navigation"
        },
        {
          "command": "invisibleErrors.showDashboard",
          "when": "view == invisibleErrors.issues",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -b",
    "watch": "tsc -b --watch"
  },
  "dependencies": {
    "@ied/core": "*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
