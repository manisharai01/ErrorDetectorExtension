{
  "name": "ied-monorepo",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:core": "npm run build -w packages/core",
    "build:cli": "npm run build -w packages/cli",
    "build:vscode": "npm run build -w packages/vscode",
    "test": "npm test --workspaces --if-present",
    "bench": "tsc -p packages/core/tsconfig.test.json && node packages/core/dist-test/test/benchmarks/perf.bench.js"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
