{
  "name": "invisible-errors-detector",
  "displayName": "Invisible Errors Detector",
  "description": "Static analysis tool that finds bugs traditional linters miss (logic, security, code smells, framework patterns).",
  "version": "0.1.0",
  "publisher": "invisible-errors",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Programming Languages", "Other"],
  "keywords": ["linter", "static-analysis", "bugs", "security", "react", "vue", "typescript"],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:vue"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      { "command": "invisibleErrors.analyzeWorkspace", "title": "Invisible Errors: Analyze Workspace" },
      { "command": "invisibleErrors.analyzeFile", "title": "Invisible Errors: Analyze Current File" },
      { "command": "invisibleErrors.clearCache", "title": "Invisible Errors: Clear Cache" },
      { "command": "invisibleErrors.showDashboard", "title": "Invisible Errors: Show Dashboard" },
      { "command": "invisibleErrors.exportReport", "title": "Invisible Errors: Export Report (JSON/HTML/SARIF)" },
      { "command": "invisibleErrors.cancelAnalysis", "title": "Invisible Errors: Cancel Running Analysis" }
    ],
    "views": {
      "explorer": [
        { "id": "invisibleErrors.issues", "name": "Invisible Errors", "icon": "$(bug)" }
      ]
    },
    "configuration": {
      "title": "Invisible Errors Detector",
      "properties": {
        "invisibleErrors.enable": { "type": "boolean", "default": true },
        "invisibleErrors.runOnSave": { "type": "boolean", "default": true },
        "invisibleErrors.runOnType": { "type": "boolean", "default": true, "description": "Lint as the user types (debounced)." },
        "invisibleErrors.debounceMs": { "type": "number", "default": 400 },
        "invisibleErrors.maxFileSize": { "type": "number", "default": 1000000 },
        "invisibleErrors.rules": {
          "type": "object",
          "default": {},
          "additionalProperties": { "type": "string", "enum": ["off", "info", "warning", "error"] },
          "description": "Per-rule severity overrides. Keys are rule IDs."
        },
        "invisibleErrors.exclude": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["**/node_modules/**", "**/dist/**", "**/out/**", "**/build/**", "**/.git/**"]
        },
        "invisibleErrors.performance": {
          "type": "object",
          "default": { "parallelAnalysis": true, "maxWorkers": 4, "cacheSize": 200 },
          "properties": {
            "parallelAnalysis": { "type": "boolean", "default": true },
            "maxWorkers": { "type": "number", "default": 4 },
            "cacheSize": { "type": "number", "default": 200 }
          }
        },
        "invisibleErrors.anyTypeThreshold": { "type": "number", "default": 5 },
        "invisibleErrors.allowConsoleInCli": { "type": "boolean", "default": true }
      }
    },
    "menus": {
      "view/title": [
        { "command": "invisibleErrors.analyzeWorkspace", "when": "view == invisibleErrors.issues", "group": "navigation" },
        { "command": "invisibleErrors.showDashboard", "when": "view == invisibleErrors.issues", "group": "navigation" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "bench": "node ./out/test/benchmarks/perf.bench.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "typescript": "^5.4.0"
  }
}
